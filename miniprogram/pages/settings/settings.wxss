/* settings.wxss */
.container {
  min-height: 100vh;
  background: #E8F5E9;
}

/* 头部 */
.header {
  padding: 48rpx 32rpx;
  text-align: center;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1D2129;
  display: block;
}

.subtitle {
  font-size: 26rpx;
  color: #8F959E;
  margin-top: 12rpx;
  display: block;
}

/* 章节 */
.section {
  padding: 0 32rpx 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1D2129;
  margin-bottom: 24rpx;
  display: block;
}

/* 设置卡片 */
.setting-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 24rpx;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-info {
  flex: 1;
}

.setting-label {
  font-size: 30rpx;
  font-weight: 500;
  color: #1D2129;
  display: block;
}

.setting-desc {
  font-size: 24rpx;
  color: #8F959E;
  margin-top: 4rpx;
  display: block;
}

.setting-switch {
  transform: scale(0.8);
}

.setting-picker {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #F5F5F5;
  border-radius: 24rpx;
}

.picker-text {
  font-size: 26rpx;
  color: #646A73;
}

.picker-arrow {
  font-size: 28rpx;
  color: #8F959E;
  margin-left: 16rpx;
}

/* 同步状态卡片 */
.sync-status-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 24rpx;
}

.sync-status-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.status-indicator {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.status-info {
  flex: 1;
}

.status-title {
  font-size: 24rpx;
  color: #8F959E;
  display: block;
}

.status-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #1D2129;
  margin-top: 4rpx;
  display: block;
}

.sync-details {
  display: flex;
  justify-content: space-around;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F0F0;
}

.detail-item {
  text-align: center;
}

.detail-label {
  font-size: 24rpx;
  color: #8F959E;
  display: block;
}

.detail-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #1D2129;
  margin-top: 4rpx;
  display: block;
}

.detail-value.highlight {
  color: #4CAF50;
}

/* 同步控制卡片 */
.sync-control-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1D2129;
  margin-bottom: 20rpx;
  display: block;
}

/* 历史记录卡片 */
.history-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  margin-top: 24rpx;
}

.history-header {
  display: flex;
  align-items: center;
  padding: 24rpx;
}

.history-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1D2129;
}

.history-count {
  font-size: 24rpx;
  color: #8F959E;
  margin-left: 12rpx;
}

.history-arrow {
  margin-left: auto;
  font-size: 32rpx;
  color: #8F959E;
}

.history-content {
  border-top: 1rpx solid #F0F0F0;
}

.history-list {
  max-height: 400rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.history-item:last-child {
  border-bottom: none;
}

.history-status {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: bold;
}

.history-info {
  flex: 1;
  margin-left: 16rpx;
}

.history-mode {
  font-size: 26rpx;
  color: #1D2129;
  display: block;
}

.history-time {
  font-size: 22rpx;
  color: #8F959E;
  margin-top: 4rpx;
  display: block;
}

.history-meta {
  text-align: right;
}

.history-synced {
  font-size: 24rpx;
  color: #4CAF50;
  display: block;
}

.history-duration {
  font-size: 20rpx;
  color: #8F959E;
  margin-top: 4rpx;
  display: block;
}

.empty-history {
  padding: 40rpx;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #8F959E;
}

.clear-history-btn {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
  color: #8F959E;
  background: #F5F5F5;
  border: none;
  border-radius: 0;
}

/* 成就网格 */
.achievements-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.achievement-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  opacity: 0.5;
  filter: grayscale(100%);
}

.achievement-card.unlocked {
  opacity: 1;
  filter: grayscale(0%);
  background: linear-gradient(135deg, #FFF8E1 0%, #FFFFFF 100%);
}

.achievement-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 12rpx;
}

.achievement-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1D2129;
  display: block;
}

.achievement-desc {
  font-size: 22rpx;
  color: #8F959E;
  margin-top: 8rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.achievement-status {
  font-size: 20rpx;
  color: #4CAF50;
  margin-top: 12rpx;
  display: block;
}

.achievement-card.locked .achievement-status {
  color: #999;
}

/* 统计网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.stat-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #4CAF50;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #8F959E;
  margin-top: 8rpx;
  display: block;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.action-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
}

.action-btn-primary {
  background: linear-gradient(135deg, #4CAF50 0%, #388E3C 100%);
  color: #FFFFFF;
}

.action-btn-secondary {
  background: #FFFFFF;
  color: #646A73;
  border: 2rpx solid #E5E6EB;
}

.action-btn-danger {
  background: #FFFFFF;
  color: #F44336;
  border: 2rpx solid #F44336;
}

.action-btn:active {
  opacity: 0.85;
}

.action-btn:disabled {
  background: #E0E0E0;
  color: #999;
}

/* 底部按钮 */
.bottom-bar {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.btn-back {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #4CAF50;
  color: #FFFFFF;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
}

/* 难度选择器 */
.difficulty-selector {
  display: flex;
  gap: 16rpx;
  padding: 0 24rpx 24rpx;
}

.difficulty-option {
  flex: 1;
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 20rpx 12rpx;
  text-align: center;
  border: 4rpx solid transparent;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.2s ease;
}

.difficulty-option:active {
  transform: scale(0.98);
}

.difficulty-option.active {
  border-width: 4rpx;
}

.difficulty-option .difficulty-icon {
  font-size: 40rpx;
  display: block;
  margin-bottom: 8rpx;
}

.difficulty-option .difficulty-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1D2129;
  display: block;
  margin-bottom: 4rpx;
}

.difficulty-option .difficulty-desc {
  font-size: 20rpx;
  color: #86909C;
  display: block;
}