/* leaderboard.wxss */
.container {
  min-height: 100vh;
  background: #E8F5E9;
}

/* 云开发状态栏 */
.cloud-status-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.cloud-status-bar.success {
  background: #E8F5E9;
  border: 1rpx solid #4CAF50;
}

.cloud-status-bar.warning {
  background: #FFF3E0;
  border: 1rpx solid #FF9800;
}

.status-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.status-text {
  flex: 1;
}

.status-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1D2129;
  display: block;
}

.status-desc {
  font-size: 24rpx;
  color: #8F959E;
  margin-top: 4rpx;
  display: block;
}

.sync-buttons {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-left: 16rpx;
}

.sync-btn {
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  border-radius: 20rpx;
  border: none;
  line-height: 1.2;
}

.sync-btn-primary {
  background: #4CAF50;
  color: #FFFFFF;
}

.sync-btn-secondary {
  background: #F5F5F5;
  color: #646A73;
  border: 1rpx solid #E5E6EB;
}

.sync-btn.syncing {
  background: #E0E0E0 !important;
  color: #999 !important;
}

.sync-btn:disabled {
  background: #E0E0E0;
  color: #999;
}

/* 加载状态 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #E0E0E0;
  border-top-color: #4CAF50;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 32rpx;
  color: #999;
}

.content {
  padding: 32rpx;
  padding-bottom: 160rpx;
}

/* 统计卡片 */
.stats-card {
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(76, 175, 80, 0.3);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 52rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 50rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* 搜索栏 */
.search-bar {
  margin-bottom: 24rpx;
}

/* 难度筛选 */
.difficulty-filter-bar {
  margin-bottom: 24rpx;
}

.difficulty-filter-list {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.difficulty-filter-item {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  border: 2rpx solid #E5E5E5;
  transition: all 0.2s ease;
}

.difficulty-filter-item.active {
  border-color: #4CAF50;
  background: #E8F5E9;
}

.filter-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.filter-name {
  font-size: 26rpx;
  color: #646A73;
}

.difficulty-filter-item.active .filter-name {
  color: #4CAF50;
  font-weight: 500;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 40rpx;
  padding: 20rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1D2129;
}

.search-clear {
  font-size: 28rpx;
  color: #999;
  padding: 8rpx;
}

/* 筛选栏 */
.filter-bar {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.filter-group {
  margin-bottom: 16rpx;
}

.filter-group:last-child {
  margin-bottom: 0;
}

.filter-label {
  font-size: 26rpx;
  color: #646A73;
  margin-bottom: 12rpx;
  display: block;
}

.filter-options {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.filter-option {
  padding: 12rpx 28rpx;
  background: #F5F5F5;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #646A73;
  transition: all 0.3s ease;
}

.filter-option.active {
  background: #4CAF50;
  color: #FFFFFF;
}

/* 章节头部 */
.section-header {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1D2129;
  display: block;
}

.section-subtitle {
  font-size: 26rpx;
  color: #8F959E;
  margin-top: 8rpx;
}

/* 排行榜列表 */
.leaderboard-list {
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.empty-state {
  padding: 80rpx 32rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #1D2129;
  display: block;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #8F959E;
}

/* 列表项 */
.lb-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.lb-item:last-child {
  border-bottom: none;
}

/* 前三名样式 */
.lb-top-1 {
  background: linear-gradient(90deg, #FFF8E1 0%, #FFFFFF 100%);
}

.lb-top-2 {
  background: linear-gradient(90deg, #F5F5F5 0%, #FFFFFF 100%);
}

.lb-top-3 {
  background: linear-gradient(90deg, #FFF3E0 0%, #FFFFFF 100%);
}

.lb-rank-wrapper {
  width: 80rpx;
  text-align: center;
}

.lb-rank {
  font-size: 36rpx;
  font-weight: 600;
}

.lb-info {
  flex: 1;
  padding: 0 24rpx;
}

.lb-main {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.lb-level {
  font-size: 30rpx;
  font-weight: 500;
  color: #1D2129;
}

.lb-difficulty {
  display: flex;
  align-items: center;
}

.difficulty-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #F5F5F5;
  color: #646A73;
}

.difficulty-tag.easy {
  background: #E8F5E9;
  color: #4CAF50;
}

.difficulty-tag.normal {
  background: #FFF3E0;
  color: #FF9800;
}

.difficulty-tag.hard {
  background: #FFEBEE;
  color: #F44336;
}

.lb-result {
  font-size: 28rpx;
}

.lb-result.win {
  color: #4CAF50;
}

.lb-result.lose {
  color: #F44336;
}

.lb-time {
  font-size: 24rpx;
  color: #8F959E;
  margin-top: 4rpx;
  display: block;
}

.lb-user {
  margin-top: 4rpx;
}

.lb-user-name {
  font-size: 24rpx;
  color: #4CAF50;
}

.lb-score-wrapper {
  text-align: right;
  flex-shrink: 0;
  padding-left: 16rpx;
}

.lb-score {
  font-size: 36rpx;
  font-weight: 700;
  color: #4CAF50;
  display: block;
  line-height: 1.2;
}

.lb-score-label {
  font-size: 24rpx;
  color: #8F959E;
}

/* 分页控件 */
.pagination {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  margin: 24rpx 0;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.page-btn {
  padding: 16rpx 28rpx;
  background: #4CAF50;
  color: #FFFFFF;
  border-radius: 24rpx;
  font-size: 28rpx;
  transition: all 0.2s ease;
  min-width: 140rpx;
  text-align: center;
}

.page-btn:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.page-btn.disabled {
  background: #E0E0E0;
  color: #999;
  pointer-events: none;
}

.page-info {
  font-size: 28rpx;
  color: #646A73;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  display: flex;
  gap: 24rpx;
}

.btn-back {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: #4CAF50;
  color: #FFFFFF;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
}

.btn-debug {
  width: 140rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: #607D8B;
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 44rpx;
  border: none;
}

/* 调试面板 */
.debug-panel {
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  margin-top: 32rpx;
  box-shadow: 0 -4rpx 32rpx rgba(0, 0, 0, 0.1);
}

.debug-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.debug-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1D2129;
}

.debug-refresh {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  background: #F5F5F5;
  color: #646A73;
  font-size: 32rpx;
  border-radius: 50%;
  border: none;
}

.debug-loading {
  font-size: 28rpx;
  color: #8F959E;
}

.debug-content {
  margin-bottom: 32rpx;
}

.debug-section {
  margin-bottom: 28rpx;
}

.debug-section:last-child {
  margin-bottom: 0;
}

.debug-section-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #1D2129;
  margin-bottom: 16rpx;
  display: block;
}

.debug-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #F9F9F9;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.debug-row:last-child {
  margin-bottom: 0;
}

.debug-label {
  font-size: 28rpx;
  color: #646A73;
}

.debug-value {
  font-size: 28rpx;
  color: #1D2129;
  font-weight: 500;
}

.debug-value.success {
  color: #4CAF50;
}

.debug-value.error {
  color: #F44336;
}

.debug-empty {
  text-align: center;
  padding: 60rpx 32rpx;
}

.debug-empty .empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.debug-empty .empty-text {
  font-size: 28rpx;
  color: #8F959E;
}

/* 建议列表 */
.debug-suggestions {
  padding-left: 8rpx;
}

.debug-suggestion {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 24rpx;
  background: #FFF8E1;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.debug-suggestion:last-child {
  margin-bottom: 0;
}

.suggestion-num {
  font-size: 26rpx;
  color: #FF9800;
  font-weight: 500;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.suggestion-text {
  font-size: 26rpx;
  color: #5D4037;
  line-height: 1.6;
}

/* 调试操作按钮 */
.debug-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.debug-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #F5F5F5;
  color: #646A73;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: 1rpx solid #E5E6EB;
  transition: all 0.3s ease;
}

.debug-btn:active {
  background: #E0E0E0;
}

/* 参与者列表 */
.section {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 0;
}

.section-arrow {
  font-size: 28rpx;
  color: #999;
  margin-left: 12rpx;
}

.participants-list {
  margin-top: 20rpx;
}

.participant-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.participant-item:last-child {
  border-bottom: none;
}

.participant-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  overflow: hidden;
  background: #F5F5F5;
  margin-right: 20rpx;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  font-size: 32rpx;
}

.participant-info {
  flex: 1;
}

.participant-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #1D2129;
  margin-bottom: 4rpx;
}

.participant-time {
  display: block;
  font-size: 24rpx;
  color: #8F959E;
}

.participant-status {
  text-align: right;
}

.status-badge {
  font-size: 24rpx;
  color: #4CAF50;
  background: #E8F5E9;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}