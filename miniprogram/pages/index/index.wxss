/**index.wxss**/
.page {
  padding: 60rpx 32rpx;
  background: #E8F5E9;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.sub {
  display: block;
  font-size: 28rpx;
  color: #999;
}

.score-box {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 48rpx;
  text-align: center;
}

.score-box text {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.start-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #4CAF50;
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  margin-bottom: 24rpx;
  border: none;
}

.start-btn:active {
  opacity: 0.85;
}

.rule-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #fff;
  color: #4CAF50;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: 2rpx solid #4CAF50;
}

.rule-btn:active {
  opacity: 0.85;
}

.leaderboard-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
  margin-top: 24rpx;
  border: none;
}

.leaderboard-btn:active {
  opacity: 0.85;
}

.settings-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #fff;
  color: #757575;
  font-size: 28rpx;
  border-radius: 40rpx;
  margin-top: 24rpx;
  border: 2rpx solid #E5E5E5;
}

.settings-btn:active {
  opacity: 0.85;
}

.user-section {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  overflow: hidden;
  background: #F5F5F5;
  margin-right: 24rpx;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  font-size: 48rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.user-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.share-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
  margin-top: 24rpx;
  border: none;
}

.share-btn:active {
  opacity: 0.85;
}

.profile-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #00BCD4 0%, #0097A7 100%);
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
  margin-top: 24rpx;
  border: none;
}

.profile-btn:active {
  opacity: 0.85;
}