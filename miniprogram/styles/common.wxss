/* 全局公共样式 - 记忆翻牌游戏 */
/* 使用纯色值，不依赖CSS变量，确保微信小程序兼容 */

/* 页面基础样式 */
page {
  background-color: #F5F5F5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: #1D2129;
  line-height: 1.5;
  box-sizing: border-box;
}

/* 通用容器 */
.container {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 按钮基础样式 */
.btn {
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  transition: all 0.2s ease;
  background: none;
  border: none;
  padding: 0;
  margin: 0;
}

.btn::after {
  border: none;
}

.btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-primary {
  background: #4CAF50;
  color: #fff;
}

.btn-secondary {
  background: #FFFFFF;
  color: #4CAF50;
  border: 2rpx solid #4CAF50;
}

.btn-large {
  height: 96rpx;
  line-height: 96rpx;
  font-size: 36rpx;
}

/* 标题样式 */
.title-large {
  font-size: 48rpx;
  font-weight: 600;
  color: #1D2129;
}

.title-medium {
  font-size: 34rpx;
  font-weight: 600;
  color: #1D2129;
}

.title-small {
  font-size: 30rpx;
  font-weight: 500;
  color: #1D2129;
}

/* 文本样式 */
.text-primary {
  color: #1D2129;
}

.text-secondary {
  color: #4E5969;
}

.text-assist {
  color: #86909C;
}

/* flex布局工具类 */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-wrap {
  flex-wrap: wrap;
}

/* 居中布局 */
.center {
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

/* 动画定义 */
@keyframes flipIn {
  0% { transform: rotateY(90deg); }
  100% { transform: rotateY(0deg); }
}

@keyframes flipOut {
  0% { transform: rotateY(0deg); }
  100% { transform: rotateY(90deg); }
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-10rpx); }
  75% { transform: translateX(10rpx); }
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.05); opacity: 0.6; }
}

@keyframes celebrate {
  0% { transform: scale(1) rotate(0deg); }
  25% { transform: scale(1.1) rotate(-5deg); }
  50% { transform: scale(1.1) rotate(5deg); }
  75% { transform: scale(1.1) rotate(-5deg); }
  100% { transform: scale(1) rotate(0deg); }
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

@keyframes matchPulse {
  0%, 100% { transform: rotateY(180deg) scale(1); }
  50% { transform: rotateY(180deg) scale(1.1); }
}